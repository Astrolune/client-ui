{
  "name": "@astrolune/client-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Astrolune client UI monorepo",
  "author": "Ankerin",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter \"./packages/*\" dev",
    "build": "pnpm --filter \"./packages/*\" build",
    "lint": "pnpm --filter \"./packages/*\" lint",
    "typecheck": "pnpm --filter \"./packages/*\" typecheck",
    "clean": "pnpm --filter \"./packages/*\" clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
