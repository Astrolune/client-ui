{
  "name": "@astrolune/app",
  "private": true,
  "author": "Ankerin",
  "description": "Astrolune",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "pretauri": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-Process astrolune_desktop -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue; if (Get-Command Get-NetTCPConnection -ErrorAction SilentlyContinue) { $ownerPids = Get-NetTCPConnection -LocalPort 5173 -State Listen -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique; foreach ($ownerPid in $ownerPids) { Stop-Process -Id $ownerPid -Force -ErrorAction SilentlyContinue } }; $exe='src-tauri\\target\\debug\\astrolune_desktop.exe'; if (Test-Path $exe) { Remove-Item $exe -Force -ErrorAction SilentlyContinue }\"",
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "tauri": "node scripts/tauri-wrapper.cjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@astrolune/core": "file:../core",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@fontsource/noto-sans": "^5.1.1",
    "@marsidev/react-turnstile": "^1.3.0",
    "@microsoft/signalr": "^8.0.17",
    "@primer/octicons-react": "^19.14.0",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-hover-card": "^1.1.5",
    "@reduxjs/toolkit": "^2.5.0",
    "@tauri-apps/api": "^2.10.1",
    "@livekit/components-react": "^2.7.5",
    "tauri-plugin-keyring-api": "^0.1.1",
    "classnames": "^2.5.1",
    "emoji-mart": "^5.6.0",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "livekit-client": "^2.17.2",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^15.7.4",
    "react-loading-skeleton": "^3.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.1.3",
    "use-sync-external-store": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "sass": "^1.87.0",
    "typescript": "^5.2.2",
    "vite": "^6.3.3"
  }
}
